# Copy this file to .env and fill in your values
# cp .env.example .env

# Remote Models Configuration (OpenAI, Claude, etc.)
# ===================================================
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com/v1
SPRING_AI_OPENAI_API_KEY=sk-your-key-here
SPRING_AI_OPENAI_CHAT_MODEL=gpt-4o-mini

# Local Models Configuration (Ollama, LM Studio, etc.)
# =====================================================
SPRING_AI_OPENAI_BASE_URL_LOCAL=http://localhost:11434/v1
SPRING_AI_OPENAI_API_KEY_LOCAL=dummy

# Model Lists
# ===========
APP_MODELS_REMOTE=gpt-4o-mini,gpt-4,gpt-3.5-turbo
APP_MODELS_LOCAL=qwen:latest,llama2

# Email / SMTP Configuration
# ==========================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
APP_MAIL_FROM=noreply@example.com

# Server Configuration
# ====================
SERVER_PORT=8080
